# ============================================================
# .env.example — 복사해서 .env.production (서버) 또는 .env.local (로컬) 로 사용
# ============================================================

# ── Google / Gemini API 키 (필수) ──
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── Google STT 서비스 계정 (WebSocket STT 사용 시 필수) ──
# Docker: credentials/ 폴더에 JSON 파일을 넣고 아래 경로 지정
GOOGLE_APPLICATION_CREDENTIALS=credentials/daisoproject-sst.json

# ── CORS 허용 Origin (쉼표 구분, *=전체 허용) ──
CORS_ORIGINS=*

# ── Infrastructure (Docker Compose가 자동 주입 — 수동 설정 불필요) ──
# ELASTIC_URL=http://elasticsearch:9200
# QDRANT_URL=http://qdrant:6333
# REDIS_URL=redis://redis:6379/0

# ── Search Index ──
ELASTIC_INDEX=products
QDRANT_COLLECTION=products

# ── Embedding ──
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001

# ── Hybrid Search 파라미터 ──
SEARCH_TOP_K_BM25=30
SEARCH_TOP_K_DENSE=30
SEARCH_TOP_K_FUSED=10
SEARCH_RRF_K=60
SEARCH_FUSION_METHOD=rrf

# ── Reranker ──
# RERANK_MODE=vendor  (mock | vendor | simulated | local)

# ── Frontend (로컬 dev에서만 설정, 배포 시 미설정 → /api 사용) ──
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FFmpeg (Windows에서 수동 설치한 경우만) ──
# FFMPEG_PATH=C:\path\to\ffmpeg\bin
